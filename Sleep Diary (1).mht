@charset "utf-8";

:root { --bg: #f6f3ef; --surface: #fcfbf9; --surface-2: #ffffff; --text: #241f1b; --muted: #746f68; --faint: #b8b2aa; --border: #ddd7cf; --primary: #01696f; --primary-2: #0b565c; --primary-soft: #d8e7e5; --good: #3d7a23; --warn: #9b6d00; --bad: #8a255c; --radius: 18px; --radius-sm: 12px; --shadow: 0 8px 24px rgba(0,0,0,.08); --max: 720px; }

[data-theme="dark"] { --bg: #161514; --surface: #1e1c1a; --surface-2: #262422; --text: #ece7e1; --muted: #a39c94; --faint: #6f6962; --border: #3a3632; --primary: #58a2ad; --primary-2: #77bcc6; --primary-soft: #243638; --shadow: 0 8px 24px rgba(0,0,0,.35); }

* { box-sizing: border-box; }

html { text-size-adjust: 100%; }

body { margin: 0px; font-family: "DM Sans", system-ui, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }

button, input, select, textarea { font: inherit; }

button { cursor: pointer; }

.wrap { max-width: var(--max); margin: 0px auto; padding: 16px 16px 96px; }

.top { position: sticky; top: 0px; z-index: 10; background: color-mix(in oklab,var(--bg) 88%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid color-mix(in oklab,var(--border) 70%, transparent); }

.topin { max-width: var(--max); margin: 0px auto; padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }

.brand { display: flex; align-items: center; gap: 12px; }

.logo { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(145deg,var(--primary),var(--primary-2)); display: grid; place-items: center; color: white; box-shadow: var(--shadow); }

.logo svg { width: 20px; height: 20px; }

.title { font-family: "DM Serif Display", serif; font-size: 1.35rem; line-height: 1; }

.sub { font-size: 0.8rem; color: var(--muted); margin-top: 2px; }

.iconbtn { border: 1px solid var(--border); background: var(--surface); color: var(--text); width: 42px; height: 42px; border-radius: 999px; display: grid; place-items: center; }

.hero { padding: 20px 0px 12px; }

.eyebrow { display: inline-flex; align-items: center; gap: 8px; background: var(--primary-soft); color: var(--primary); padding: 8px 12px; border-radius: 999px; font-size: 0.82rem; font-weight: 700; }

.hero h1 { font-family: "DM Serif Display", serif; font-size: clamp(2rem, 5vw, 2.8rem); line-height: 1.05; margin: 14px 0px 10px; }

.hero p { color: var(--muted); margin: 0px; max-width: 42ch; }

.grid { display: grid; gap: 16px; }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); padding: 16px; }

.card h2 { font-size: 1rem; margin: 0px 0px 14px; font-weight: 700; }

.sectionhead { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }

.dot { width: 10px; height: 10px; border-radius: 999px; background: var(--primary); }

.tabs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 12px 0px 18px; }

.tab { border: 1px solid var(--border); background: var(--surface); padding: 11px 8px; border-radius: 999px; color: var(--muted); font-size: 0.83rem; font-weight: 700; }

.tab.active { background: var(--primary); border-color: var(--primary); color: rgb(255, 255, 255); }

.panel { display: none; }

.panel.active { display: block; }

.fields { display: grid; gap: 14px; }

.two { display: grid; gap: 14px; grid-template-columns: 1fr 1fr; }

.label { font-size: 0.8rem; font-weight: 700; color: var(--muted); margin: 0px 0px 6px; text-transform: uppercase; letter-spacing: 0.03em; }

.hint { font-size: 0.78rem; color: var(--faint); margin-top: 6px; }

.input, .select, .area { width: 100%; min-height: 48px; border: 1.5px solid var(--border); background: var(--surface-2); color: var(--text); border-radius: 14px; padding: 12px 14px; outline: none; }

.input:focus, .select:focus, .area:focus { border-color: var(--primary); box-shadow: 0 0 0 4px color-mix(in oklab,var(--primary) 18%, transparent); }

.area { min-height: 88px; resize: vertical; }

.counter { display: flex; align-items: center; gap: 14px; }

.countbtn { width: 46px; height: 46px; border-radius: 999px; border: 1.5px solid var(--border); background: var(--surface-2); font-size: 1.4rem; }

.count { font-size: 1.5rem; font-weight: 700; color: var(--primary); min-width: 24px; text-align: center; }

.stars { display: flex; gap: 8px; flex-wrap: wrap; }

.star { width: 46px; height: 46px; border-radius: 999px; border: 1px solid var(--border); background: var(--surface-2); font-size: 1.15rem; opacity: 0.45; }

.star.on { opacity: 1; background: var(--primary-soft); border-color: color-mix(in oklab,var(--primary) 30%, var(--border)); }

.primary { width: 100%; min-height: 52px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 16px; background: linear-gradient(180deg,var(--primary),var(--primary-2)); color: rgb(255, 255, 255); font-weight: 700; box-shadow: var(--shadow); }

.row { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; padding: 12px 0px; border-top: 1px solid color-mix(in oklab,var(--border) 70%, transparent); }

.row:first-child { border-top-width: medium; border-top-style: none; border-top-color: currentcolor; }

.row strong { display: block; font-size: 0.94rem; }

.row span { display: block; color: var(--muted); font-size: 0.84rem; }

.time { font-weight: 700; color: var(--primary); white-space: nowrap; }

.entry { padding: 14px; border: 1px solid var(--border); border-radius: 16px; background: var(--surface-2); display: grid; gap: 10px; }

.entrytop { display: flex; justify-content: space-between; gap: 10px; align-items: center; }

.entrydate { font-weight: 700; color: var(--primary); }

.badge { font-size: 0.76rem; padding: 5px 9px; border-radius: 999px; font-weight: 700; }

.good { background: rgb(215, 229, 208); color: var(--good); }

.ok { background: rgb(235, 224, 194); color: var(--warn); }

.low { background: rgb(231, 210, 220); color: var(--bad); }

.mini { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

.mini div { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 10px; }

.mini label { display: block; font-size: 0.7rem; color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; }

.mini strong { display: block; font-size: 0.92rem; margin-top: 3px; }

.notice { padding: 12px 14px; border-radius: 14px; background: var(--primary-soft); color: var(--text); font-size: 0.88rem; }

.empty { padding: 28px 18px; text-align: center; color: var(--muted); }

.footerbar { position: fixed; left: 0px; right: 0px; bottom: 0px; background: color-mix(in oklab,var(--bg) 92%, transparent); backdrop-filter: blur(10px); border-top: 1px solid color-mix(in oklab,var(--border) 70%, transparent); padding: 10px 16px calc(10px + env(safe-area-inset-bottom)); }

.footerbar .inner { max-width: var(--max); margin: 0px auto; }

.toast { position: fixed; left: 50%; bottom: 86px; transform: translateX(-50%) translateY(20px); background: var(--text); color: var(--bg); padding: 10px 16px; border-radius: 999px; opacity: 0; pointer-events: none; transition: 0.22s; font-size: 0.85rem; box-shadow: var(--shadow); }

.toast.show { opacity: 1; transform: translateX(-50%) translateY(0px); }

@media (max-width: 560px) {
  .tabs { grid-template-columns: repeat(2, 1fr); }
  .two, .mini { grid-template-columns: 1fr; }
}
